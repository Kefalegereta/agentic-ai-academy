# Copia este fichero a .env y rellena los valores reales.
# El .env NUNCA se sube a git (esta en .gitignore).

# --- Vector store: PostgreSQL + pgvector (Azure) ---
PG_URL=postgresql://usuario:password@host:5432/postgres?sslmode=require

# --- Azure OpenAI (embeddings + generacion) ---
AZURE_OPENAI_ENDPOINT=https://tu-recurso.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=tu-clave-azure
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
